# ============================================
# ABS 存续期智能提醒系统 - 环境变量配置
# 复制此文件为 .env 并根据需要修改
# ============================================

# ---- 应用端口 ----
APP_PORT=3001

# ---- 数据库 (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=admin123
DB_DATABASE=ABS

# ---- JWT ----
JWT_SECRET=abs-jwt-secret-key-2024

# ---- 邮件通知 (可选，使用 QQ 邮箱 SMTP) ----
# 如果不配置，邮件通知功能将静默失败，不影响系统其他功能
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_authorization_code
SMTP_FROM=noreply@abs.com